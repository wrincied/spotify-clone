{
    "name": "spotify-clone",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "serve:ssr:spotify-clone": "node dist/spotify-clone/server/server.mjs"
    },
    "prettier": {
        "arrowParens": "always",
        "bracketSpacing": true,
        "bracketSameLine": false,
        "htmlWhitespaceSensitivity": "css",
        "insertPragma": false,
        "printWidth": 80,
        "proseWrap": "always",
        "quoteProps": "as-needed",
        "requirePragma": false,
        "semi": true,
        "singleQuote": true,
        "tabWidth": 2,
        "trailingComma": "all",
        "useTabs": false,
        "embeddedLanguageFormatting": "auto",
        "overrides": [
            {
                "files": "*.html",
                "options": {
                    "parser": "angular",
                    "singleAttributePerLine": true
                }
            }
        ]
    },
    "private": true,
    "packageManager": "npm@11.6.2",
    "dependencies": {
        "@angular/common": "^21.0.0",
        "@angular/compiler": "^21.0.0",
        "@angular/core": "^21.0.0",
        "@angular/forms": "^21.0.0",
        "@angular/platform-browser": "^21.0.0",
        "@angular/platform-server": "^21.0.0",
        "@angular/router": "^21.0.0",
        "@angular/ssr": "^21.0.1",
        "express": "^5.1.0",
        "fast-average-color": "^9.5.0",
        "firebase": "^12.6.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.0.1",
        "@angular/cli": "^21.0.1",
        "@angular/compiler-cli": "^21.0.0",
        "@types/express": "^5.0.1",
        "@types/node": "^20.17.19",
        "jsdom": "^27.1.0",
        "prettier": "^3.7.4",
        "typescript": "~5.9.2",
        "vitest": "^4.0.8"
    }
}
