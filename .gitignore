# --- Dependencies (Зависимости) ---
node_modules/
backend/node_modules/
# package-lock.json лучше оставлять для стабильности версий, но если мешает — можно добавить сюда.

# --- Angular / Build Output (Сборка фронта) ---
dist/
tmp/
out-tsc/
bazel-out/
/path/to/dist/
.angular/
.sass-cache/
connect.lock
coverage/
lib/
test-results.xml

# --- Logs (Логи) ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*

# --- Environment Variables & Secrets (КРИТИЧНО ВАЖНО) ---
# Это предотвращает утечку паролей и API ключей
.env
.env.local
.env.*.local
backend/.env
src/environments/environment.ts # Если там хранятся секретные ключи (для продакшена лучше инжектить при сборке)

# --- IDE & System (Настройки редактора и системы) ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Backend Specifics (Бэкенд) ---
# Игнорируем музыку и медиа (Github не для хранения mp3)
backend/public/music/*.mp3
backend/public/music/*.wav
backend/public/images/ # Если есть загрузка картинок
spotify-backend/

# Локальная база данных (JSON), чтобы локальные тесты не ломали данные на сервере/у других
backend/db/*.json
# Но можно оставить categories.json, если это статичные данные, добавив !:
!backend/db/categories.json

# --- Firebase ---
.firebase/
src/environments/environment.ts
